Icon=@ICON@
Terminal=false
StartupNotify=true
StartupWMClass=@STARTUP_WM_CLASS@
Categories=AudioVideo;Audio;Music;
Keywords=ENCORE;Ableton;Live;DAW;Audio;Music;
