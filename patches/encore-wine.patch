+    dtor = (void *)GetProcAddress(msvcp,
+            "??_D?$basic_istream@DU?$char_traits@D@std@@@std@@QEAAXXZ");
+    ok(!!ctor, "basic_istream constructor export not found\n");
+    ok(!!move_ctor, "basic_istream move constructor export not found\n");
