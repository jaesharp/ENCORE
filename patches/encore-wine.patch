+    DO_FUNC(dbus_message_new_method_call); \
+    DO_FUNC(dbus_message_iter_append_fixed_array); \
+    DO_FUNC(dbus_message_unref);
+
+#define DO_FUNC(f) static typeof(f) * p_##f
+DBUS_FUNCS;
