+}
+
+static UINT get_multisz_lenW(const WCHAR *str)
+{
+    const WCHAR *s;
+
+    if (!str) return 0;
+    s = str;
+    while (*s) s += lstrlenW(s) + 1;
+    s++;
+    return s - str;
