+    size_t len;
+
+    if (!path || !*path)
+        return;
+
+    if (!(This->options & FOS_PICKFOLDERS))
+    {
+        slash = wcsrchr(path, '\\');
+        if (!slash) slash = wcsrchr(path, '/');
+        if (!slash || slash == path)
+            return;
+
+        len = (size_t)(slash - path);
+        if (len == 2 && path[1] == ':') len++;
+        if (!(dir = malloc((len + 1) * sizeof(WCHAR))))
+            return;
+        memcpy(dir, path, len * sizeof(WCHAR));
+        dir[len] = 0;
+        folder = dir;
+    }
+
+    if (SUCCEEDED(SHParseDisplayName(folder, NULL, &pidl, 0, NULL)))
+    {
+        if (SUCCEEDED(SHCreateShellItem(NULL, NULL, pidl, &psi)))
+        {
+            if (This->psi_folder) IShellItem_Release(This->psi_folder);
+            This->psi_folder = psi;
+        }
+        ILFree(pidl);
+    }
+    free(dir);
