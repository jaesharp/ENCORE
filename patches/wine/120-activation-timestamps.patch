ENCORE Wine patch -- real timestamps in _NET_ACTIVE_WINDOW requests (winex11)

Ported from shibco/ableton-linux patches/0017 (shibco / shibacomputer,
cade@parare.al) -- a fix to LGPL-2.1+ Wine's winex11. Regenerated against
wine-11.13; behaviour unchanged.

winex11 sends _NET_ACTIVE_WINDOW activation requests with timestamp 0; strict
window managers (GNOME >= 50 mutter) silently drop them under focus-stealing
prevention, and Wine's pending-request dedup then suppresses every further
request -- one dropped request wedges activation for the whole session (menus
open-then-close or not at all, keyboard shortcuts inert, clicks on inactive
windows die in the WM_MOUSEACTIVATE dance). Send the last real input
timestamp instead and re-send when a newer one exists, so activation
self-heals on user input. Upstream-PR candidate.
See shibco notes/ABLETON-WINE-INPUT-BUG.md.

diff --git a/dlls/winex11.drv/window.c b/dlls/winex11.drv/window.c
index 297695749a..202260080a 100644
--- a/dlls/winex11.drv/window.c
+++ b/dlls/winex11.drv/window.c
@@ -2041,10 +2041,23 @@ void set_net_active_window( HWND hwnd, HWND previous )
     BOOL withdrawn = FALSE;
     Window window;
     XEvent xev;
+    Time time = CurrentTime;
 
     if (!is_net_supported( x11drv_atom(_NET_ACTIVE_WINDOW) )) return;
     if (!(window = X11DRV_get_whole_window( hwnd ))) return;
-    if (data->pending_state.net_active_window == window) return;
+
+    /* Use the timestamp of the last user input we processed: mutter's focus-stealing
+     * prevention silently drops activation requests with timestamp 0 (GNOME 50), which
+     * previously deadlocked the request state machine below for the whole session. */
+    if (EVENT_x11_time_to_win32_time( 0 ))
+        time = NtUserGetThreadState( UserThreadStateMessageTime ) - EVENT_x11_time_to_win32_time( 0 );
+
+    /* Skip only exact repeats: if the WM ignored a previous request for this window
+     * (e.g. it carried an older timestamp than the WM's focus-stealing cutoff), a new
+     * user interaction yields a fresh timestamp and must be allowed to retry, else the
+     * window can never be activated again for the rest of the session. */
+    if (data->current_state.net_active_window == window && !data->net_active_window_serial) return;
+    if (data->pending_state.net_active_window == window && time == data->net_active_window_time) return;
     if (window_set_pending_activate( hwnd, &withdrawn )) return;
 
     xev.xclient.type = ClientMessage;
@@ -2055,12 +2068,13 @@ void set_net_active_window( HWND hwnd, HWND previous )
     xev.xclient.send_event = True;
     xev.xclient.format = 32;
     xev.xclient.data.l[0] = 2; /* source: pager */
-    xev.xclient.data.l[1] = 0; /* timestamp */
+    xev.xclient.data.l[1] = time;
     xev.xclient.data.l[2] = X11DRV_get_whole_window( previous ); /* current active */
     xev.xclient.data.l[3] = 0;
     xev.xclient.data.l[4] = 0;
 
     data->net_active_window_serial = NextRequest( data->display );
+    data->net_active_window_time = time;
 
     if (withdrawn)
     {
@@ -2071,7 +2085,8 @@ void set_net_active_window( HWND hwnd, HWND previous )
     }
     data->pending_state.net_active_window = window;
 
-    TRACE( "requesting _NET_ACTIVE_WINDOW %p/%lx serial %lu\n", hwnd, window, data->net_active_window_serial );
+    TRACE( "requesting _NET_ACTIVE_WINDOW %p/%lx serial %lu time %lu\n", hwnd, window,
+           data->net_active_window_serial, data->net_active_window_time );
     XSendEvent( data->display, DefaultRootWindow( data->display ), False,
                 SubstructureRedirectMask | SubstructureNotifyMask, &xev );
 }
diff --git a/dlls/winex11.drv/x11drv.h b/dlls/winex11.drv/x11drv.h
index 4325c99e5c..240b6f337f 100644
--- a/dlls/winex11.drv/x11drv.h
+++ b/dlls/winex11.drv/x11drv.h
@@ -437,6 +437,7 @@ struct x11drv_thread_data
     struct display_state pending_state;       /* display state tracking the pending / requested state */
     struct display_state current_state;       /* display state tracking the current X11 state */
     unsigned long net_active_window_serial;   /* serial of last pending _NET_ACTIVE_WINDOW request */
+    Time     net_active_window_time;          /* user timestamp of last _NET_ACTIVE_WINDOW request */
 };
 
 extern struct x11drv_thread_data *x11drv_init_thread_data(void);
