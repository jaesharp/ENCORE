+static void test_basic_istream_move(void)
+{
+#ifdef _WIN64
+    typedef void *(__cdecl *istream_ctor_t)(void *, void *, MSVCP_bool, MSVCP_bool);
+    typedef void *(__cdecl *istream_move_ctor_t)(void *, void *, MSVCP_bool);
+    typedef void *(__cdecl *istream_move_assign_t)(void *, void *);
+    typedef void (__cdecl *istream_dtor_t)(void *);
+    BYTE left[256] = {0}, right[256] = {0}, moved[256] = {0};
+    istream_move_ctor_t move_ctor;
+    istream_move_assign_t move_assign;
+    istream_ctor_t ctor;
+    istream_dtor_t dtor;
+    LONGLONG *left_count = (LONGLONG *)(left + sizeof(void *));
+    LONGLONG *right_count = (LONGLONG *)(right + sizeof(void *));
+    LONGLONG *moved_count = (LONGLONG *)(moved + sizeof(void *));
+    void *ret;
+
+    ctor = (void *)GetProcAddress(msvcp,
+            "??0?$basic_istream@DU?$char_traits@D@std@@@std@@QEAA@PEAV?$basic_streambuf@DU?$char_traits@D@std@@@1@_N@Z");
+    move_ctor = (void *)GetProcAddress(msvcp,
+            "??0?$basic_istream@DU?$char_traits@D@std@@@std@@IEAA@$$QEAV01@@Z");
+    move_assign = (void *)GetProcAddress(msvcp,
+            "??4?$basic_istream@DU?$char_traits@D@std@@@std@@IEAAAEAV01@$$QEAV01@@Z");
+    dtor = (void *)GetProcAddress(msvcp,
+            "??_D?$basic_istream@DU?$char_traits@D@std@@@std@@QEAAXXZ");
+    ok(!!ctor, "basic_istream constructor export not found\n");
+    ok(!!move_ctor, "basic_istream move constructor export not found\n");
+    ok(!!move_assign, "basic_istream move assignment export not found\n");
+    ok(!!dtor, "basic_istream destructor export not found\n");
+    if (!ctor || !move_ctor || !move_assign || !dtor) return;
+
+    ctor(left, NULL, FALSE, TRUE);
+    ctor(right, NULL, FALSE, TRUE);
+    *left_count = 11;
+    *right_count = 22;
+
+    ret = move_assign(left, right);
+    ok(ret == left, "move assignment returned %p, expected %p\n", ret, left);
+    ok(*left_count == 22, "left count is %I64d, expected 22\n", *left_count);
+    ok(*right_count == 11, "right count is %I64d, expected 11\n", *right_count);
+
+    ret = move_ctor(moved, right, TRUE);
+    ok(ret == moved, "move constructor returned %p, expected %p\n", ret, moved);
+    ok(*moved_count == 11, "moved count is %I64d, expected 11\n", *moved_count);
+    ok(*right_count == 0, "right count is %I64d, expected 0\n", *right_count);
+
+    dtor(moved);
+    dtor(right);
+    dtor(left);
+#endif
+}
+
 START_TEST(msvcp140)
