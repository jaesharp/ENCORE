 static HRESULT STDMETHODCALLTYPE dxgi_output_WaitForVBlank(IDXGIOutput6 *iface)
 {
-    static BOOL once = FALSE;
+    struct dxgi_output *output = impl_from_IDXGIOutput6(iface);
+    LARGE_INTEGER counter, delay, frequency;
+    struct wined3d_display_mode mode;
+    LONGLONG period, remaining;
+    UINT refresh_rate;
+    NTSTATUS status;
+    HRESULT hr;
 
-    if (!once++)
-        FIXME("iface %p stub!\n", iface);
-    else
-        TRACE("iface %p stub!\n", iface);
+    TRACE("iface %p.\n", iface);
 
-    return E_NOTIMPL;
+    wined3d_mutex_lock();
+    hr = wined3d_output_get_display_mode(output->wined3d_output, &mode, NULL);
+    wined3d_mutex_unlock();
+    if (FAILED(hr))
+        return hr;
+
+    if (!QueryPerformanceCounter(&counter) || !QueryPerformanceFrequency(&frequency))
+        return E_FAIL;
+
+    /* There is no host-vblank primitive at this layer. Still return a paced
+     * success result: GUI frameworks use this method as their repaint clock,
+     * and an E_NOTIMPL result can leave invalid regions queued forever. */
+    refresh_rate = mode.refresh_rate;
+    if (refresh_rate < 24 || refresh_rate > 1000)
+        refresh_rate = 60;
+    if (!(period = frequency.QuadPart / refresh_rate))
+        return E_FAIL;
+
+    remaining = period - counter.QuadPart % period;
+    delay.QuadPart = -((remaining * 10000000 + frequency.QuadPart - 1)
+            / frequency.QuadPart);
+    if (!delay.QuadPart)
+        delay.QuadPart = -1;
+    if ((status = NtDelayExecution(FALSE, &delay)) < 0)
+        return HRESULT_FROM_NT(status);
+
+    return S_OK;
 }
 
