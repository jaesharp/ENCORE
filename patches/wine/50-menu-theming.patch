+static BOOL use_ableton_live_menu_theme( HWND hwnd )
+{
+    static const WCHAR class_prefix[] =
+        {'A','b','l','e','t','o','n',' ','L','i','v','e',' ','W','i','n','d','o','w'};
+    WCHAR class_name[64];
+    UNICODE_STRING name = {.Buffer = class_name, .MaximumLength = sizeof(class_name)};
+    const char *value = getenv( "ENCORE_ABLETON_MENU_THEME" );
+    INT len;
+
+    if (!value || !value[0] || value[0] == '0') return FALSE;
+    len = NtUserGetClassName( hwnd, FALSE, &name );
+    return len >= ARRAY_SIZE(class_prefix) &&
+           !memcmp( class_name, class_prefix, sizeof(class_prefix) );
+}
+
+static COLORREF contrasting_text_color( COLORREF background )
+{
+    unsigned int luminance = 299 * GetRValue(background) +
+                             587 * GetGValue(background) +
+                             114 * GetBValue(background);
+
+    return luminance >= 128000 ? RGB(0, 0, 0) : RGB(255, 255, 255);
+}
+
+static COLORREF sample_ableton_live_menu_theme( HWND hwnd, const RECT *menu_rect )
+{
+    static const unsigned int sample_columns[] = {6, 1, 2, 3, 4, 5, 7};
+    COLORREF samples[ARRAY_SIZE(sample_columns) * 3];
+    unsigned int best = 0, best_count = 0, count = 0, i, j;
+    int width = menu_rect->right - menu_rect->left;
+    struct ratio dpi = get_dpi_for_window( hwnd );
+    HDC hdc;
+
+    if (!(hdc = NtUserGetDCEx( hwnd, 0, DCX_CACHE | DCX_WINDOW ))) return CLR_INVALID;
+
+    for (i = 0; i < ARRAY_SIZE(sample_columns); ++i)
+    {
+        int x = menu_rect->left + width * sample_columns[i] / 8;
+
+        for (j = 0; j < 3; ++j)
+        {
+            int y = menu_rect->bottom + map_user_dpi( 10 + j * 2, dpi );
+            COLORREF color = NtGdiGetPixel( hdc, x, y );
+
+            if (color != CLR_INVALID) samples[count++] = color;
+        }
+    }
+    NtUserReleaseDC( hwnd, hdc );
+    if (!count) return CLR_INVALID;
+
+    for (i = 0; i < count; ++i)
+    {
+        unsigned int matches = 1;
+
+        for (j = i + 1; j < count; ++j)
+            if (samples[j] == samples[i]) matches++;
+        if (matches > best_count)
+        {
+            best = i;
+            best_count = matches;
+        }
+    }
+    return samples[best];
+}
