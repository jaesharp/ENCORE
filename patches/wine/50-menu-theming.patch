+static void test_menu_bar_height(void)
+{
+    BOOL (WINAPI *pAdjustWindowRectExForDpi)(RECT *, DWORD, BOOL, DWORD, UINT);
+    UINT (WINAPI *pGetDpiForWindow)(HWND);
+    RECT adjusted = {0}, client, window;
+    DWORD style, ex_style;
+    HMODULE user32;
+    HMENU menu;
+    HWND hwnd;
+    UINT dpi;
+    int actual, expected;
+
+    user32 = GetModuleHandleA("user32.dll");
+    pAdjustWindowRectExForDpi = (void *)GetProcAddress(user32, "AdjustWindowRectExForDpi");
+    pGetDpiForWindow = (void *)GetProcAddress(user32, "GetDpiForWindow");
+    if (!pAdjustWindowRectExForDpi || !pGetDpiForWindow)
+    {
+        win_skip("Per-monitor DPI APIs are not available.\n");
+        return;
+    }
+
+    menu = CreateMenu();
+    ok(menu != NULL, "CreateMenu failed with error %ld.\n", GetLastError());
+    AppendMenuA(menu, MF_STRING, 1, "File");
+    hwnd = CreateWindowExA(0, (LPCSTR)MAKEINTATOM(atomMenuCheckClass), NULL,
+                           WS_OVERLAPPEDWINDOW | WS_VISIBLE, 100, 100, 640, 480,
+                           NULL, menu, NULL, NULL);
+    ok(hwnd != NULL, "CreateWindowEx failed with error %ld.\n", GetLastError());
+    if (!hwnd)
+    {
+        DestroyMenu(menu);
+        return;
+    }
+
+    dpi = pGetDpiForWindow(hwnd);
+    style = GetWindowLongA(hwnd, GWL_STYLE);
+    ex_style = GetWindowLongA(hwnd, GWL_EXSTYLE);
+    pAdjustWindowRectExForDpi(&adjusted, style, TRUE, ex_style, dpi);
+    GetWindowRect(hwnd, &window);
+    GetClientRect(hwnd, &client);
+    actual = (window.bottom - window.top) - (client.bottom - client.top);
+    expected = adjusted.bottom - adjusted.top + MulDiv(4, dpi, 96);
+
+    ok(actual == expected, "Got non-client height %d, expected %d at %u DPI.\n",
+       actual, expected, dpi);
+
+    DestroyWindow(hwnd);
+    DestroyMenu(menu);
+}
