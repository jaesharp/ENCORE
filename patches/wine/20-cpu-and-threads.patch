+/*
+ * Proton-compatible CPU topology override syntax:
+ *
+ *   WINE_CPU_TOPOLOGY=<logical-cpu-count>
+ *   WINE_CPU_TOPOLOGY=<logical-cpu-count>:<host-cpu-id>,...
+ *   WINE_CPU_TOPOLOGY=<physical-core-count>s:<host-cpu-id>,...
+ *
+ * The last form reports two SMT siblings for each physical core.  The explicit
+ * mapping forms also translate Windows affinity masks to the selected host CPUs.
+ */
+void fill_cpu_override(void)
+{
+    const char *env_override = getenv("WINE_CPU_TOPOLOGY");
+    unsigned int available_cpu_count = 0, logical_cpu_count, i;
+#if defined(__linux__) && defined(HAVE_SCHED_SETAFFINITY)
+    cpu_set_t available_cpu_set;
+#endif
+    unsigned long value;
+    BOOL smt = FALSE;
+    char *s;
+
+    memset( &cpu_override, 0, sizeof(cpu_override) );
+    if (!env_override || !*env_override) return;
+
+#if defined(__linux__) && defined(HAVE_SCHED_SETAFFINITY)
+    CPU_ZERO( &available_cpu_set );
+    if (sched_getaffinity( 0, sizeof(available_cpu_set), &available_cpu_set ))
+    {
+        ERR("Failed to query the allowed host CPU set.\n");
+        return;
+    }
+    for (i = 0; i < MAXIMUM_HOST_CPU_COUNT; ++i)
+        if (CPU_ISSET( i, &available_cpu_set )) ++available_cpu_count;
+#else
+    FIXME("WINE_CPU_TOPOLOGY requires Linux sched affinity support.\n");
+    return;
+#endif
+    if (!available_cpu_count)
+    {
+        ERR("No allowed host CPUs are representable by the current topology mapping.\n");
+        return;
+    }
+
+    if (*env_override < '0' || *env_override > '9') goto error;
+    errno = 0;
+    value = strtoul(env_override, &s, 10);
+    if (errno == ERANGE || !value || value > MAXIMUM_PROCESSORS) goto error;
+    logical_cpu_count = value;
+
+    if (!*s)
+    {
+        if (logical_cpu_count > available_cpu_count)
+        {
+            TRACE("Override CPU count %u exceeds available CPU count %u; ignoring.\n",
+                  logical_cpu_count, available_cpu_count);
+            return;
+        }
+
+#if defined(__linux__) && defined(HAVE_SCHED_SETAFFINITY)
+        {
+            static const char core_info[] = "/sys/devices/system/cpu/cpu%u/topology/%s";
+            unsigned int host_core_id[MAXIMUM_HOST_CPU_COUNT];
+            unsigned int attempt, count = 0, j;
+            char name[MAX_PATH];
+
+            fill_performance_core_info();
+            for (i = 0; i < MAXIMUM_HOST_CPU_COUNT; ++i)
+            {
+                FILE *f;
+
+                host_core_id[i] = i;
+                if (!CPU_ISSET( i, &available_cpu_set )) continue;
+                snprintf(name, sizeof(name), core_info, i, "thread_siblings_list");
+                if ((f = fopen(name, "r")))
+                {
+                    if (fscanf(f, "%u", &host_core_id[i]) != 1) host_core_id[i] = i;
+                    fclose(f);
+                }
+            }
+
+            for (attempt = 0; attempt < 3; ++attempt)
+            {
+                count = 0;
+                memset( cpu_override.siblings_mask, 0, sizeof(cpu_override.siblings_mask) );
+                for (i = 0; i < MAXIMUM_HOST_CPU_COUNT && count < logical_cpu_count; ++i)
+                {
+                    if (!CPU_ISSET( i, &available_cpu_set )) continue;
+                    if (attempt < 2 && performance_cores_capacity)
+                    {
+                        if (i / 32 >= performance_cores_capacity) break;
+                        if (!(performance_cores[i / 32] & (1u << (i % 32)))) continue;
+                    }
+
+                    cpu_override.mapping.host_cpu_id[count] = i;
+                    cpu_override.siblings_mask[count] = (ULONG_PTR)1 << count;
+                    for (j = 0; j < count; ++j)
+                    {
+                        if (host_core_id[cpu_override.mapping.host_cpu_id[j]] != host_core_id[i])
+                            continue;
+                        if (!attempt) goto skip_cpu;
+                        cpu_override.siblings_mask[j] |= (ULONG_PTR)1 << count;
+                        cpu_override.siblings_mask[count] |= (ULONG_PTR)1 << j;
+                    }
+                    ++count;
+skip_cpu:
+                    ;
+                }
+                if (count == logical_cpu_count) break;
+            }
+            if (count != logical_cpu_count) goto error;
+        }
+#endif
+        cpu_override.mapping.cpu_count = logical_cpu_count;
+        goto done;
+    }
+
+    if (tolower((unsigned char)*s) == 's')
+    {
+        if (logical_cpu_count > MAXIMUM_PROCESSORS / 2) goto error;
+        logical_cpu_count *= 2;
+        smt = TRUE;
+        ++s;
+    }
+    if (*s++ != ':') goto error;
+
+    for (i = 0; i < logical_cpu_count; ++i)
+    {
+        unsigned int j;
+        char *next;
+
+        if (i && *s++ != ',') goto error;
+        if (*s < '0' || *s > '9') goto error;
+        errno = 0;
+        value = strtoul(s, &next, 10);
+        if (errno == ERANGE || next == s || value >= MAXIMUM_HOST_CPU_COUNT) goto error;
+#if defined(__linux__) && defined(HAVE_SCHED_SETAFFINITY)
+        if (!CPU_ISSET( value, &available_cpu_set )) goto error;
+#else
+        goto error;
+#endif
+        for (j = 0; j < i; ++j)
+            if (cpu_override.mapping.host_cpu_id[j] == value) goto error;
+
+        cpu_override.mapping.host_cpu_id[i] = value;
+        cpu_override.siblings_mask[i] = smt ? (ULONG_PTR)3 << (i & ~1) : (ULONG_PTR)1 << i;
+        s = next;
+    }
+    if (*s) goto error;
+    cpu_override.mapping.cpu_count = logical_cpu_count;
+
+done:
+    for (i = 0; i < cpu_override.mapping.cpu_count; ++i)
+    {
+        unsigned int core_id = i, j;
+
+        for (j = 0; j < i; ++j)
+        {
+            if (!(cpu_override.siblings_mask[i] & ((ULONG_PTR)1 << j))) continue;
+            core_id = cpu_override.mapping.core_id[j];
+            break;
+        }
+        cpu_override.mapping.core_id[i] = core_id;
+    }
+    if (ERR_ON(ntdll))
+    {
+        MESSAGE("wine: overriding CPU configuration, %u logical CPUs, host CPUs ",
+                cpu_override.mapping.cpu_count);
+        for (i = 0; i < cpu_override.mapping.cpu_count; ++i)
+        {
+            if (i) MESSAGE(",");
+            MESSAGE("%u", cpu_override.mapping.host_cpu_id[i]);
+        }
+        MESSAGE(".\n");
+    }
+    return;
+
+error:
+    memset( &cpu_override, 0, sizeof(cpu_override) );
+    ERR("Invalid WINE_CPU_TOPOLOGY string %s. Expected <count>, <count>:<host CPUs>, or <cores>s:<host CPUs>.\n",
+        debugstr_a(env_override));
+}
+
+void adopt_cpu_override(const struct cpu_topology_override *mapping)
+{
+    unsigned int i, j;
+
+    if (!mapping || !mapping->cpu_count)
+    {
+        memset( &cpu_override, 0, sizeof(cpu_override) );
+        return;
+    }
+    if (mapping->cpu_count > ARRAY_SIZE(cpu_override.siblings_mask)) goto invalid;
+    for (i = 0; i < mapping->cpu_count; ++i)
+    {
+        if (mapping->host_cpu_id[i] >= MAXIMUM_HOST_CPU_COUNT ||
+            mapping->core_id[i] >= mapping->cpu_count)
+            goto invalid;
+        for (j = 0; j < i; ++j)
+            if (mapping->host_cpu_id[j] == mapping->host_cpu_id[i]) goto invalid;
+    }
+
+    if (cpu_override.mapping.cpu_count == mapping->cpu_count &&
+        !memcmp( cpu_override.mapping.host_cpu_id, mapping->host_cpu_id,
+                 mapping->cpu_count * sizeof(mapping->host_cpu_id[0]) ) &&
+        !memcmp( cpu_override.mapping.core_id, mapping->core_id,
+                 mapping->cpu_count ))
+        return;
+
+    memset( &cpu_override, 0, sizeof(cpu_override) );
+    cpu_override.mapping = *mapping;
+    for (i = 0; i < mapping->cpu_count; ++i)
+    {
+        for (j = 0; j < mapping->cpu_count; ++j)
+            if (mapping->core_id[i] == mapping->core_id[j])
+                cpu_override.siblings_mask[i] |= (ULONG_PTR)1 << j;
+    }
+    fill_performance_core_info();
+    return;
+
+invalid:
+    ERR("Ignoring invalid CPU topology returned by wineserver.\n");
+    memset( &cpu_override, 0, sizeof(cpu_override) );
+}
+
+const struct cpu_topology_override *get_cpu_topology_override(void)
+{
+    return cpu_override.mapping.cpu_count ? &cpu_override.mapping : NULL;
+}
