+
+/* record an unexpected Unix thread exit and schedule safe server-side cleanup */
+static void handle_unix_thread_exit( struct thread *thread, const char *reason )
+{
+    int unix_pid = thread->unix_pid;
+    int unix_tid = thread->unix_tid;
+
+    if (unix_tid == -1) return;
+
+    if (thread->state != RUNNING)
+    {
+        thread->unix_pid = -1;
+        thread->unix_tid = -1;
+        if (debug_level)
+            fprintf( stderr, "%04x: *unix exit* pid=%d tid=%d %s\n",
+                     thread->id, unix_pid, unix_tid, reason );
+        return;
+    }
