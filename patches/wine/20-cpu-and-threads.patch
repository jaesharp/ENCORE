+    /* kill_thread() drops the running-thread and initial object references. Keep
+     * one until a zero-delay callback can run outside the current list traversal
+     * or ptrace caller. */
+    grab_object( thread );
+    if (!add_timeout_user( 0, terminate_exited_unix_thread, thread ))
+        fatal_error( "out of memory while retiring exited Unix thread %04x\n", thread->id );
+
+    thread->unix_pid = -1;
+    thread->unix_tid = -1;
+    if (!thread->exit_code_set)
+    {
+        thread->exit_code = STATUS_UNSUCCESSFUL;
+        thread->exit_code_set = true;
+    }
+    fprintf( stderr, "%04x: Unix peer pid=%d tid=%d exited while its Windows thread "
+             "remained running (%s); retiring it\n", thread->id, unix_pid, unix_tid, reason );
