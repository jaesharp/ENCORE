+/* Map a Linux CPU-list file to the compact virtual processor mask selected by
+ * WINE_CPU_TOPOLOGY. Unlike the bitmap parser, this also handles host CPU IDs
+ * above the native Windows affinity-mask width. */
+static BOOL sysfs_map_cpu_list(const char *filename, ULONG_PTR *mask)
+{
+    FILE *f;
+    BOOL parsed = FALSE;
+
+    if (!(f = fopen(filename, "r"))) return FALSE;
+    while (!feof(f))
+    {
+        unsigned int beg, end, i;
+        char op;
+
+        if (fscanf(f, "%u%c ", &beg, &op) != 2) break;
+        if (op == '-')
+        {
+            if (fscanf(f, "%u%c ", &end, &op) != 2) break;
+        }
+        else end = beg;
+        if (end < beg) break;
+
+        parsed = TRUE;
+        for (i = 0; i < cpu_override.mapping.cpu_count; ++i)
+        {
+            unsigned int host_cpu = cpu_override.mapping.host_cpu_id[i];
+
+            if (host_cpu >= beg && host_cpu <= end) *mask |= (ULONG_PTR)1 << i;
+        }
+    }
+    fclose( f );
+    return parsed;
+}
