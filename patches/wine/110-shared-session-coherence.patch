ENCORE Wine patch -- shared-session view coherence (win32u + server)

Ported from shibco/ableton-linux patches/0018 + 0019 (shibco / shibacomputer,
cade@parare.al) -- fixes to LGPL-2.1+ Wine. Regenerated against wine-11.13;
behaviour unchanged.

Clients map wineserver's shared session memfd read-only, and ntdll maps
read-only views MAP_PRIVATE, which is not coherent for this memfd: views go
permanently stale, find_shared_session_object() reads id 0 where the server
wrote a class object, NtUserRegisterClassExW fails, and window creation dies
with a swallowed null-call AV in WM_NCCREATE (~2.4 s per AV inside Live's
vectored crash handler -- felt as multi-second menu freezes and intermittent
"VST3: plug window creation failed"). Map session views with
SECTION_MAP_READ|SECTION_MAP_WRITE + PAGE_READWRITE so ntdll uses MAP_SHARED
(read-only fallback kept); the server pre-dirties grown session blocks and
fixes a block-match off-by-one. shibco verified 30k register-class +
create/destroy-window iterations across mapping growths with zero failures.
Vanilla-Wine bug, not specific to any rendering stack; upstream-PR candidate.
See shibco notes/ABLETON-WINE-INPUT-BUG.md.

diff --git a/dlls/win32u/winstation.c b/dlls/win32u/winstation.c
index 3da9acdd3a..a372b6bda6 100644
--- a/dlls/win32u/winstation.c
+++ b/dlls/win32u/winstation.c
@@ -120,21 +120,38 @@ static NTSTATUS map_shared_session_block( SIZE_T offset, SIZE_T size, struct ses
 
     if (!(block = calloc( 1, sizeof(*block) ))) return STATUS_NO_MEMORY;
 
+    /* Map the view with write access so ntdll uses MAP_SHARED: read-only views
+     * are mapped MAP_PRIVATE on Linux, and private views of the session memfd
+     * can end up permanently stale (they stop observing wineserver's writes),
+     * which makes session objects read as zeroes: window class registration and
+     * window creation then fail at random ("plug window creation failed",
+     * popup menus dying in WM_NCCREATE). We never write through the view. */
     InitializeObjectAttributes( &attr, &name, 0, NULL, NULL );
-    if ((status = NtOpenSection( &handle, SECTION_MAP_READ, &attr )))
-        WARN( "Failed to open shared session section, status %#x\n", status );
-    else
+    if (!(status = NtOpenSection( &handle, SECTION_MAP_READ | SECTION_MAP_WRITE, &attr )))
     {
         if ((status = NtMapViewOfSection( handle, GetCurrentProcess(), (void **)&block->data, 0, 0,
-                                          &off, &block->size, ViewUnmap, 0, PAGE_READONLY )))
-            WARN( "Failed to map shared session block, status %#x\n", status );
+                                          &off, &block->size, ViewUnmap, 0, PAGE_READWRITE )))
+            WARN( "Failed to map shared session block read-write, status %#x\n", status );
+        NtClose( handle );
+    }
+    if (status)
+    {
+        InitializeObjectAttributes( &attr, &name, 0, NULL, NULL );
+        if ((status = NtOpenSection( &handle, SECTION_MAP_READ, &attr )))
+            WARN( "Failed to open shared session section, status %#x\n", status );
         else
         {
-            list_add_tail( &session_blocks, &block->entry );
-            block->offset = off.QuadPart;
-            assert( block->offset + block->size > block->offset );
+            if ((status = NtMapViewOfSection( handle, GetCurrentProcess(), (void **)&block->data, 0, 0,
+                                              &off, &block->size, ViewUnmap, 0, PAGE_READONLY )))
+                WARN( "Failed to map shared session block, status %#x\n", status );
+            NtClose( handle );
         }
-        NtClose( handle );
+    }
+    if (!status)
+    {
+        list_add_tail( &session_blocks, &block->entry );
+        block->offset = off.QuadPart;
+        assert( block->offset + block->size > block->offset );
     }
 
     if (status) free( block );
@@ -153,7 +170,7 @@ static NTSTATUS find_shared_session_block( SIZE_T offset, SIZE_T size, struct se
 
     LIST_FOR_EACH_ENTRY( block, &session_blocks, struct session_block, entry )
     {
-        if (block->offset < offset && offset + size <= block->offset + block->size)
+        if (block->offset <= offset && offset + size <= block->offset + block->size)
         {
             *ret = block;
             pthread_mutex_unlock( &session_lock );
@@ -180,9 +197,12 @@ const shared_object_t *find_shared_session_object( object_id_t id, mem_size_t of
 
     if (id && !(status = find_shared_session_block( offset, sizeof(*object), &block )))
     {
+        object_id_t read_id;
         object = (const shared_object_t *)(block->data + offset - block->offset);
-        if (id == shared_object_get_id( object )) return object;
-        WARN( "Session object id doesn't match expected id %s\n", wine_dbgstr_longlong(id) );
+        if (id == (read_id = shared_object_get_id( object ))) return object;
+        WARN( "Session object id %s at offset %s doesn't match expected id %s (block data %p offset %s size %s)\n",
+              wine_dbgstr_longlong(read_id), wine_dbgstr_longlong(offset), wine_dbgstr_longlong(id),
+              block->data, wine_dbgstr_longlong(block->offset), wine_dbgstr_longlong(block->size) );
     }
 
     return NULL;
diff --git a/server/mapping.c b/server/mapping.c
index a53b6b6830..47337972a1 100644
--- a/server/mapping.c
+++ b/server/mapping.c
@@ -1445,6 +1445,14 @@ void set_session_mapping( struct mapping *mapping )
         return;
     }
 
+    /* Dirty every page up front: the mapping is a sparse memfd, and reading a
+     * hole through a client's read-only MAP_PRIVATE view faults in the shared
+     * zero page, which never observes pages the server allocates later by
+     * writing (the client then sees permanently-stale zero session objects:
+     * window class registration / window creation fail at random). Writing
+     * allocates real shmem pages so in-place updates stay visible. */
+    memset( tmp, 0, size );
+
     block->data = tmp;
     block->offset = 0;
     block->used_size = sizeof(*shared_session);
@@ -1477,6 +1485,10 @@ static struct session_block *grow_session_mapping( mem_size_t needed )
         return NULL;
     }
 
+    /* see set_session_mapping: allocate real shmem pages so client-side
+     * read-only MAP_PRIVATE views never latch the hole zero page */
+    memset( tmp, 0, new_size - old_size );
+
     block->data = tmp;
     block->offset = old_size;
     block->used_size = 0;
